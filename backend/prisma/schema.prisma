generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  employee
  manager
  admin
  super_admin
}

enum ContractType {
  PERMANENT
  FIXED_TERM
}

enum WorkingHours {
  FULL
  PARTIAL
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum VacationType {
  ANNUAL
  MEDICAL
  PARENTAL
  UNPAID
}

enum VacationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  password     String
  role         Role      @default(employee)
  refreshToken String?   @unique
  companyId    Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company      Company?  @relation(fields: [companyId], references: [id])
  employee     Employee?
}

model Company {
  id            Int              @id @default(autoincrement())
  name          String
  slug          String           @unique
  legalAddress  String
  city          String
  country       String
  bankName      String?
  iban          String?
  legalRepName  String
  legalRepTitle String
  deletedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  users         User[]
  employees     Employee[]
  departments   Department[]
  invitations   Invitation[]
  profileRO     CompanyProfileRO?
}

model Department {
  id          Int        @id @default(autoincrement())
  companyId   Int
  name        String
  managerId   Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  company     Company    @relation(fields: [companyId], references: [id])
  employees   Employee[]

  @@unique([companyId, name])
}

model Invitation {
  id         Int              @id @default(autoincrement())
  companyId  Int
  email      String
  role       Role
  token      String           @unique
  status     InvitationStatus
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime         @default(now())

  company    Company          @relation(fields: [companyId], references: [id])
}

model Employee {
  id              Int            @id @default(autoincrement())
  companyId       Int
  userId          Int?           @unique
  departmentId    Int?

  // Universal personal data
  firstName       String
  lastName        String
  dateOfBirth     DateTime?
  placeOfBirth    String?
  nationality     String?
  citizenship     String?
  studies         String?
  phone           String?
  personalEmail   String?

  // Universal address
  address         String?
  city            String?
  region          String?
  country         String?
  postalCode      String?

  // Universal employment data
  jobTitle        String
  workLocation    String?
  startDate       DateTime
  contractType    ContractType
  contractEndDate DateTime?
  contractNumber  String
  contractDate    DateTime
  workingHours    WorkingHours
  partialHours    Float?
  probationDays   Int?
  grossSalary     Float
  currency        String

  // Universal vacation
  vacationDaysPerYear Int
  vacationDaysUsed    Int        @default(0)
  vacationCarryOver   Int        @default(0)

  // Status
  status          EmployeeStatus @default(ACTIVE)
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  company          Company           @relation(fields: [companyId], references: [id])
  user             User?             @relation(fields: [userId], references: [id])
  department       Department?       @relation(fields: [departmentId], references: [id])
  vacationRequests VacationRequest[]
  profileRO        EmployeeProfileRO?

  @@unique([companyId, contractNumber])
}

model VacationRequest {
  id          Int            @id @default(autoincrement())
  employeeId  Int
  companyId   Int
  type        VacationType
  startDate   DateTime
  endDate     DateTime
  days        Int
  status      VacationStatus
  approvedBy  Int?
  note        String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  employee    Employee       @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([companyId])
}

// ─── Romanian Profiles ───────────────────────────────────────────────────────

model CompanyProfileRO {
  id            Int      @id @default(autoincrement())
  companyId     Int      @unique
  cui           String   @unique
  caenCode      String
  county        String
  tradeRegister String?
  vatPayer      Boolean
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id])
}

model EmployeeProfileRO {
  id             Int      @id @default(autoincrement())
  employeeId     Int      @unique
  cnp            String
  ciSeries       String
  ciNumber       String
  ciIssuedBy     String
  ciIssuedAt     DateTime
  ciExpiresAt    DateTime
  corCode        String
  reviSalNumber  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  employee       Employee @relation(fields: [employeeId], references: [id])

  @@unique([cnp])
}